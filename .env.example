# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/cleanse-ayurveda

# JWT
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Shiprocket
SHIPROCKET_EMAIL=your_shiprocket_email
SHIPROCKET_PASSWORD=your_shiprocket_password
# Tracking webhook security token (set the SAME value in Shiprocket dashboard:
# Settings > API > Webhooks). Sent back to us as the x-api-key header.
SHIPROCKET_WEBHOOK_TOKEN=your_long_random_webhook_token
# Pickup location (must match a registered pickup nickname + its pincode in Shiprocket)
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_PICKUP_PINCODE=110001
# Warehouse address for return reverse-pickups (destination of returned goods)
SHIPROCKET_PICKUP_NAME=Warehouse
SHIPROCKET_PICKUP_ADDRESS=
SHIPROCKET_PICKUP_CITY=
SHIPROCKET_PICKUP_STATE=
SHIPROCKET_PICKUP_PHONE=
# Optional: force a specific courier id (else Shiprocket auto-assigns recommended)
SHIPROCKET_DEFAULT_COURIER_ID=
# NDR: auto re-attempts before forcing RTO
SHIPROCKET_NDR_MAX_REATTEMPTS=2
# Default package dimensions (cm) / weight (kg)
SHIPROCKET_PKG_LENGTH=20
SHIPROCKET_PKG_BREADTH=15
SHIPROCKET_PKG_HEIGHT=10
SHIPROCKET_PKG_WEIGHT=0.5
# Admin address for shipment-exception (lost/damaged) alerts
ADMIN_NOTIFY_EMAIL=admin@cleanse.com

# MSG91 (server-side OTP access-token verification)
# Fill from the MSG91 dashboard to enable backend verification, then remove the
# temporary happy-path block in auth.controller.js (verifyWidgetToken).
MSG91_AUTHKEY=your_msg91_account_authkey
# MSG91_VERIFY_URL=https://control.msg91.com/api/v5/widget/verifyAccessToken

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AWS S3 + CloudFront
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=your_bucket_name
CLOUDFRONT_URL=https://your-distribution.cloudfront.net

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Cleanse Ayurveda <noreply@cleanse.com>

# WhatsApp (slide.synquic.com BSP)
WHATSAPP_API_BASE=https://slide.synquic.com/api/v1
# Secret API key (sk_live_…). Server-side only — never expose to the browser.
WHATSAPP_API_KEY=your_slide_api_key
# Shared secret for slide's inbound webhook (button replies). Sent as x-api-key.
WHATSAPP_WEBHOOK_TOKEN=your_long_random_webhook_token
# Hold COD orders until the customer approves on WhatsApp (needs the inbound
# webhook, or use the admin confirm/cancel fallback). Off by default.
WHATSAPP_COD_HOLD=false
# Template names + language (override as templates change in the BSP)
WHATSAPP_TPL_ORDER_CONFIRM=order_confirmation_2
WHATSAPP_TPL_ORDER_SUMMARY=order_summary_1
WHATSAPP_TEMPLATE_LANG=en

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173
